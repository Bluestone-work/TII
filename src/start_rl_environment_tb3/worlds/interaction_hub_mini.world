    </link>
  </model>

  <!-- 动态障碍物 dyn_obs_0~7，默认停在四臂远端，由 obstacle_mover 接管 -->
  <model name="dyn_obs_0">
    <static>true</static>
    <pose>-4.3 -0.6 0.4 0 0 0</pose>
    <link name="link">
      <collision name="collision"><geometry><cylinder><radius>0.22</radius><length>0.8</length></cylinder></geometry></collision>
      <visual name="visual"><geometry><cylinder><radius>0.22</radius><length>0.8</length></cylinder></geometry></visual>
    </link>
  </model>

