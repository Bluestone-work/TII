<?xml version="1.0" ?>
<sdf version="1.6">
<world name="warehouse_aisles">
  <!-- Gazebo ROS State Plugin - provides /set_entity_state service -->
  <plugin name='gazebo_ros_state' filename='libgazebo_ros_state.so'>
    <ros>
      <argument>model_states:=model_states_demo</argument>
    </ros>
    <update_rate>1.0</update_rate>
  </plugin>

  <include>
    <uri>model://ground_plane</uri>
  </include>
  <light name="studio_sun" type="directional">
    <cast_shadows>1</cast_shadows>
    <pose>0 0 18 0 -0.35 0.2</pose>
    <diffuse>0.96 0.94 0.90 1</diffuse>
    <specular>0.16 0.16 0.16 1</specular>
    <attenuation>
      <range>1000</range>
      <constant>0.82</constant>
      <linear>0.006</linear>
      <quadratic>0.0008</quadratic>
    </attenuation>
    <direction>-0.35 0.18 -0.92</direction>
  </light>
  <light name="fill_light" type="point">
    <pose>0 0 8 0 0 0</pose>
    <diffuse>0.40 0.45 0.50 1</diffuse>
    <specular>0.03 0.03 0.03 1</specular>
    <attenuation>
      <range>28</range>
      <constant>0.72</constant>
      <linear>0.02</linear>
      <quadratic>0.001</quadratic>
    </attenuation>
  </light>
  <scene>
    <ambient>0.56 0.58 0.62 1</ambient>
    <background>0.90 0.93 0.98 1</background>
    <shadows>1</shadows>
  </scene>

  <model name="b_north">
