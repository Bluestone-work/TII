  <!-- ════════════════════════════════════════════════════════════════
       动态障碍物 dyn_obs_0~7  —  由 obstacle_mover 节点驱动（50 Hz）
       停靠在地图安全区域，obstacle_mover 启动后接管位置控制。
       LiDAR 对 static model 完全有效（碰撞几何正常生效）。
       ════════════════════════════════════════════════════════════════ -->
  <model name="dyn_obs_0">
    <static>true</static>
    <pose>-5.1 -3.6 0.4 0 0 0</pose>
    <link name="link">
      <collision name="collision"><geometry><cylinder><radius>0.22</radius><length>0.8</length></cylinder></geometry></collision>
